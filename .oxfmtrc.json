{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": false,
  "trailingComma": "none",
  "printWidth": 100,
  "ignorePatterns": [
    "docs/**",
    "fraction/**",
    "tests/**",
    "reports/**",
    "dist/**",
    "node_modules/**",
    "packages/*/dist/**",
    "**/*.md"
  ]
}
