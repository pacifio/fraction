{
  "name": "fraction",
  "version": "0.0.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "import": "./dist/effect.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts src/effect.ts --outdir dist --target bun --format esm && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
    "check": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.33",
    "@effect/sql-sqlite-bun": "4.0.0-beta.33",
    "@huggingface/transformers": "^3.8.1",
    "chrono-node": "2.9.0",
    "effect": "4.0.0-beta.33"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.33"
  }
}
